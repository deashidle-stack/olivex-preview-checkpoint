<section class="trust-strip" aria-label="Butikkfordeler">
  {% for block in section.blocks %}
    <div {{ block.shopify_attributes }}>
      <strong>{{ block.settings.heading }}</strong>
      <span>{{ block.settings.text }}</span>
    </div>
  {% endfor %}
</section>

{% schema %}
{
  "name": "Trust strip",
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "SSL inkludert" },
        { "type": "text", "id": "text", "label": "Text", "default": "Sikker betaling" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust strip",
      "blocks": [
        { "type": "item", "settings": { "heading": "SSL inkludert", "text": "Shopify-hostet sikker betaling" } },
        { "type": "item", "settings": { "heading": "Vipps og kort", "text": "Norsk checkout-mønster" } },
        { "type": "item", "settings": { "heading": "Posten/Bring", "text": "Valg, etiketter og sporing" } },
        { "type": "item", "settings": { "heading": "SEO fra start", "text": "Produktskjema og faginnhold" } }
      ]
    }
  ]
}
{% endschema %}
