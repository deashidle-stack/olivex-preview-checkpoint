<section class="section" id="products">
  <div class="section-heading">
    {% if section.settings.eyebrow != blank %}
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.text != blank %}
      <p>{{ section.settings.text }}</p>
    {% endif %}
  </div>
  <div class="product-grid">
    {% for block in section.blocks %}
      {% render 'product-card-lab', product: block.settings.product %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Product showcase",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Nettbutikk" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ditt daglige rituale" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "15–20 ml hver morgen. Den kan drikkes bar som en \"helseshot\", eller helles over kald mat." }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [{ "type": "product", "id": "product", "label": "Product" }]
    }
  ],
  "max_blocks": 2,
  "presets": [
    {
      "name": "Product showcase",
      "blocks": [{ "type": "product" }, { "type": "product" }]
    }
  ]
}
{% endschema %}
