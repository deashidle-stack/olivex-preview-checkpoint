<section class="section">
  <div class="section-heading">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.text != blank %}
      <p>{{ section.settings.text }}</p>
    {% endif %}
  </div>
  <div class="lab-notes-grid">
    {% for article in section.settings.blog.articles limit: 4 %}
      <article>
        <p class="eyebrow">{{ article.published_at | date: '%d.%m.%Y' }}</p>
        <h3><a href="{{ article.url }}">{{ article.title }}</a></h3>
        <p>{{ article.excerpt_or_content | strip_html | truncate: 130 }}</p>
      </article>
    {% else %}
      {% for block in section.blocks %}
        <article {{ block.shopify_attributes }}>
          <p class="eyebrow">{{ block.settings.label }}</p>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Lab Notes",
  "settings": [
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Lab Notes" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Faginnhold som bygger tillit før kjøp." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Artikler bør forklare produktkvalitet, analyse og bruk uten å gå utover lovlige claims." }
  ],
  "blocks": [
    {
      "type": "fallback",
      "name": "Fallback article",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Tema" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Hvordan lese en analyseattest" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Forklar måleverdier, batch og hva kunden bør se etter." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lab Notes",
      "blocks": [
        { "type": "fallback", "settings": { "label": "Tema", "heading": "Hva er polyfenoler i olivenolje?", "text": "En kort og claim-safe forklaring av råvarens dokumentasjon." } },
        { "type": "fallback", "settings": { "label": "Tema", "heading": "Hvordan lese en analyseattest", "text": "Forklar måleverdier, batch og hva kunden bør se etter." } }
      ]
    }
  ]
}
{% endschema %}
