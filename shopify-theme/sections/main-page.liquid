<section class="section">
  <div class="section-heading">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ page.title }}</h1>
  </div>
  <div class="rte">
    {{ page.content }}
  </div>
</section>

{% schema %}
{
  "name": "Main page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Informasjon" }
  ]
}
{% endschema %}
