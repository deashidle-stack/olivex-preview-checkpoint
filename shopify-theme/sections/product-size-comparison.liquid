{% liquid
  assign comparison_product = product
  if comparison_product == blank and section.settings.product != blank
    assign comparison_product = section.settings.product
  endif
%}

{% if comparison_product != blank %}
  <section class="section size-comparison-section" aria-labelledby="SizeComparisonTitle-{{ section.id }}">
    <div class="section-heading">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 id="SizeComparisonTitle-{{ section.id }}">{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>

    <div class="size-table-wrap">
      <table class="size-compare-table">
        <caption>
          {{ section.settings.caption }}
        </caption>
        <thead>
          <tr>
            <th scope="col">{{ 'products.size' | t }}</th>
            <th scope="col">{{ 'products.duration' | t }}</th>
            <th scope="col">{{ 'products.price' | t }}</th>
            <th scope="col">{{ 'products.price_per_ml' | t }}</th>
            <th scope="col">{{ 'products.use_case' | t }}</th>
            <th scope="col">{{ 'products.choose' | t }}</th>
          </tr>
        </thead>
        <tbody>
          {% for variant in comparison_product.variants limit: 2 %}
            {% liquid
              assign ml_string = variant.title | downcase | replace: 'milliliter', '' | replace: 'ml', '' | replace: ' ', '' | replace: ',', '.'
              assign ml_value = ml_string | plus: 0
              assign duration = variant.metafields.lab.duration
              assign use_case = variant.metafields.lab.use_case

              if duration == blank
                if forloop.index == 1
                  assign duration = section.settings.first_variant_duration
                else
                  assign duration = section.settings.second_variant_duration
                endif
              endif

              if use_case == blank
                if forloop.index == 1
                  assign use_case = section.settings.first_variant_use_case
                else
                  assign use_case = section.settings.second_variant_use_case
                endif
              endif
            %}
            <tr>
              <th scope="row" data-label="{{ 'products.size' | t }}">{{ variant.title }}</th>
              <td data-label="{{ 'products.duration' | t }}">{{ duration }}</td>
              <td data-label="{{ 'products.price' | t }}">{{ variant.price | money }}</td>
              <td data-label="{{ 'products.price_per_ml' | t }}">
                {% if ml_value > 0 %}
                  {{ variant.price | divided_by: ml_value | money }}/ml
                {% else %}
                  {{ 'products.requires_size_data' | t }}
                {% endif %}
              </td>
              <td data-label="{{ 'products.use_case' | t }}">{{ use_case }}</td>
              <td data-label="{{ 'products.choose' | t }}">
                {% form 'product', comparison_product, class: 'size-compare-form' %}
                  <input type="hidden" name="id" value="{{ variant.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button class="product-form__submit" type="submit" {% unless variant.available %}disabled{% endunless %}>
                    {% if variant.available %}
                      {{ 'products.add_to_cart' | t }}
                    {% else %}
                      {{ 'products.sold_out' | t }}
                    {% endif %}
                  </button>
                {% endform %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Product size comparison",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product fallback"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Størrelser"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sammenlign størrelser"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Basert på 15-20 ml daglig bruk."
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Table caption",
      "default": "Sammenligning av tilgjengelige OliveX-størrelser"
    },
    {
      "type": "text",
      "id": "first_variant_duration",
      "label": "First variant duration",
      "default": "Kommer"
    },
    {
      "type": "text",
      "id": "second_variant_duration",
      "label": "Second variant duration",
      "default": "Kommer"
    },
    {
      "type": "text",
      "id": "first_variant_use_case",
      "label": "First variant use case",
      "default": "Avklares med endelig størrelse"
    },
    {
      "type": "text",
      "id": "second_variant_use_case",
      "label": "Second variant use case",
      "default": "Avklares med endelig størrelse"
    }
  ],
  "presets": [
    {
      "name": "Product size comparison"
    }
  ]
}
{% endschema %}
