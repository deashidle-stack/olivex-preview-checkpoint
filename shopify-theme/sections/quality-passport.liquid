{% liquid
  assign passport_product = section.settings.product
  if passport_product == blank and product
    assign passport_product = product
  endif

  assign batch_id = passport_product.metafields.lab.batch_id | default: section.settings.batch_id
  assign origin = passport_product.metafields.lab.origin | default: section.settings.origin
  assign lab_name = passport_product.metafields.lab.lab_name | default: section.settings.lab_name
  assign method = passport_product.metafields.lab.test_method | default: section.settings.test_method
  assign certificate = passport_product.metafields.lab.certificate_url | default: section.settings.certificate_url
  assign serving = passport_product.metafields.lab.serving_condition | default: section.settings.serving_condition
%}

<section class="quality-passport" id="quality-passport">
  <div class="quality-passport__image" aria-hidden="true">
    {% if section.settings.image %}
      {{ section.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: section.settings.image.alt | escape }}
    {% endif %}
  </div>
  <div class="quality-passport__content">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>

    <div class="passport-card">
      <div class="metric-row">
        <span>Batch</span>
        <strong>{{ batch_id | default: 'Vises her' }}</strong>
      </div>
      <div class="metric-row">
        <span>Opprinnelse</span>
        <strong>{{ origin | default: 'Vises her' }}</strong>
      </div>
      <div class="metric-row">
        <span>Laboratorium</span>
        <strong>{{ lab_name | default: 'Vises her' }}</strong>
      </div>
      <div class="metric-row">
        <span>Metode</span>
        <strong>{{ method | default: 'Vises her' }}</strong>
      </div>
      <div class="metric-row">
        <span>Claim-kontekst</span>
        <strong>{{ serving | default: 'Dose og vilkår vises her' }}</strong>
      </div>
    </div>

    {% if certificate != blank %}
      <a class="button" href="{{ certificate }}" target="_blank" rel="noopener">Åpne sertifikat</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Analysebevis",
  "settings": [
    { "type": "product", "id": "product", "label": "Optional product source" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Analysebevis" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Analysebevis" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Når analysebeviset er klart, legges opprinnelse, metode, relevante måleverdier og PDF-lenke inn her." },
    { "type": "text", "id": "batch_id", "label": "Fallback batch ID", "default": "Vises her" },
    { "type": "text", "id": "origin", "label": "Fallback origin", "default": "Vises her" },
    { "type": "text", "id": "lab_name", "label": "Fallback lab name", "default": "Vises her" },
    { "type": "text", "id": "test_method", "label": "Fallback test method", "default": "Vises her" },
    { "type": "url", "id": "certificate_url", "label": "Fallback certificate URL" },
    { "type": "text", "id": "serving_condition", "label": "Fallback serving condition", "default": "Dose og vilkår vises her" }
  ],
  "presets": [{ "name": "Analysebevis" }]
}
{% endschema %}
