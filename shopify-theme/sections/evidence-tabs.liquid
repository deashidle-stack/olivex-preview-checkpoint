<section class="section">
  <div class="section-heading">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.text != blank %}
      <p>{{ section.settings.text }}</p>
    {% endif %}
  </div>
  <div class="evidence-grid">
    {% for block in section.blocks %}
      <article {{ block.shopify_attributes }}>
        <p class="eyebrow">{{ block.settings.label }}</p>
        <h3>{{ block.settings.heading }}</h3>
        <p>{{ block.settings.text }}</p>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Evidence modules",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Dokumentasjon" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Hvorfor vanlig ekstra virgin olivenolje ikke er nok" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "De fleste forbrukere vet at ekstra virgin olivenolje er sunt. Det mange ikke vet, er at helsefordelene i all hovedsak drives av mikroskopiske plantestoffer som kalles polyfenoler." }
  ],
  "blocks": [
    {
      "type": "module",
      "name": "Module",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "01" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Opprinnelse" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Region, produksjon og lagring forklares tett på kjøpsflyten." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Evidence modules",
      "blocks": [
        { "type": "module", "settings": { "label": "01", "heading": "EUs offisielle helsepåstand", "text": "For å kunne bruke EUs offisielle helsepåstand, må en olivenolje inneholde minst 250 mg polyfenoler per kilo." } },
        { "type": "module", "settings": { "label": "02", "heading": "Vanlig olivenolje faller ofte lavt", "text": "En standard olivenolje fra matbutikken ligger ofte rett rundt eller under denne grensen." } },
        { "type": "module", "settings": { "label": "03", "heading": "Vår olje er annerledes", "text": "Den er høstet tidlig og presset under strenge temperaturkrav. Resultatet er en olje med 600–700 mg/l polyfenoler." } },
        { "type": "module", "settings": { "label": "04", "heading": "Ditt daglige rituale", "text": "15–20 ml hver morgen. Brukes bar som helseshot eller over kald mat." } }
      ]
    }
  ]
}
{% endschema %}
